## Ignore Visual Studio temporary files, build results, and files generated by popular extensions.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/

# Your specific backend paths
CatanBackend/bin/
CatanBackend/obj/

# Visual Studio 2015/2017 cache/options directory
.vs/
.vscode/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Visual Studio working folder
.vs/

# IIS Express
*.vspscc
.applicationhost.config

# DotCover
.idea/
*.dcvr

# JetBrains Rider
.idea/

# OS generated files
.DS_Store
Thumbs.db

# Dotnet stuff
project.lock.json
project.fragment.lock.json
artifacts/

# Runtime files
*.log
*.pid

# NuGet
*.nupkg
*.snupkg
.nuget/packages/
packages/

# Entity Framework
Migrations/

# StyleCop
StyleCopReport.xml

# MSBuild binary and log files
*.binlog

# Backup & temp files
*.tmp
*.bak
*.old

# Publish outputs
publish/
appsettings.Development.json

# Node (if you're hosting a React app inside the solution)
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log
.fake